# Скопируйте этот файл в server/.env и заполните значения.
# Все секреты backend хранятся ТОЛЬКО здесь и не попадают во frontend.

# === Обязательные ===
# Строка подключения к PostgreSQL (Yandex MDB либо локальный для dev).
DATABASE_URL=postgres://user:pass@localhost:5432/stroyfoto

# Секрет для подписи JWT access tokens (HS256). Минимум 32 символа.
# На проде заменить на длинный random (например, openssl rand -hex 32).
JWT_ACCESS_SECRET=change-me-to-a-long-random-string-min-32-chars

# === Имеют дефолты (можно не указывать) ===
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d

# CORS: список origin через запятую.
CORS_ORIGINS=http://localhost:5173

# Сервер.
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# === Cloud.ru Object Storage (для /api/storage/presign) ===
# Без этих значений endpoint /api/storage/presign вернёт 500 CLOUDRU_NOT_CONFIGURED.
CLOUDRU_TENANT_ID=
CLOUDRU_KEY_ID=
CLOUDRU_KEY_SECRET=
CLOUDRU_BUCKET=
CLOUDRU_ENDPOINT=https://s3.cloud.ru
CLOUDRU_REGION=ru-central-1

# === Cloudflare R2 (опционально, только для legacy migration GET) ===
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Supabase (публичные ключи; anon-ключ публичный по дизайну). Обязательны.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# URL доверенного Cloudflare Worker, выдающего короткоживущие presigned URL
# к приватному Cloudflare R2. Обязательна — без неё приложение падает на
# старте (строгая валидация в src/shared/config/env.ts). Без trailing slash.
# Деплой и настройка — см. worker/README.md.
VITE_PRESIGN_URL=https://stroyfoto-signer.example.workers.dev

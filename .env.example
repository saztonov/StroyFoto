# Supabase (публичные ключи; anon-ключ публичный по дизайну). Обязательны.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Подпись presigned URL к приватному Cloudflare R2 делает Supabase Edge
# Function `sign` (см. supabase/functions/sign/). Все R2-секреты хранятся
# в Supabase через `supabase secrets set` и никогда не попадают в клиент.
# Никаких дополнительных VITE_*-переменных для R2 не нужно.

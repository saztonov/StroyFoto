{
  "name": "stroyfoto",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "server:dev": "tsx watch server/src/server.ts",
    "server:build": "tsc -p server/tsconfig.json",
    "server:start": "node server/dist/server.js",
    "dev:all": "concurrently -n vite,api -c cyan,magenta \"npm:dev\" \"npm:server:dev\"",
    "migrate:db": "bash scripts/db/apply-migrations.sh",
    "db:schema:pull": "tsx scripts/db/export-schema.ts"
  },
  "dependencies": {
    "@ant-design/icons": "^5.5.1",
    "@fastify/cors": "^9.0.1",
    "@photo-sphere-viewer/core": "^5.14.1",
    "antd": "^5.21.4",
    "aws4fetch": "^1.0.20",
    "bcryptjs": "^2.4.3",
    "browser-image-compression": "^2.0.2",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "idb": "^8.0.3",
    "jose": "^5.9.6",
    "pdfjs-dist": "^5.6.205",
    "pg": "^8.13.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "react-zoom-pan-pinch": "^4.0.3",
    "uuid": "^14.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.16.11",
    "@types/pg": "^8.11.10",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "concurrently": "^8.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.2",
    "vite": "^6.4.2",
    "vite-plugin-pwa": "^0.21.2"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5"
  }
}
